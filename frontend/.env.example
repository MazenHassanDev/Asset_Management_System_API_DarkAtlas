# Frontend configuration (Vite). Copy to .env and fill in.

# Base URL for the API. Use "/api" to go through the Vite dev proxy
# (vite.config.js -> http://localhost:8000), which sidesteps CORS in dev.
# Or point straight at the backend, e.g. http://localhost:8000/api
VITE_API_URL=/api

# false = talk to the real Django API, true = in-memory mock (no server needed)
VITE_USE_MOCK=false

# Organization API key for the X-API-Key header. Mint one with:
#   cd api && python manage.py create_org "Acme Corp"
# and paste the printed key here.
VITE_API_KEY=
